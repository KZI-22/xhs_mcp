XHS_MCP_TRANSPORT=stdio
XHS_MCP_HOST=127.0.0.1
XHS_MCP_PORT=8765
XHS_MCP_PATH=/mcp
# XHS_MCP_AUTH_TOKEN=replace-with-a-strong-random-token
# XHS_MCP_ALLOW_NON_LOOPBACK=false
# XHS_MCP_ALLOWED_HOSTS=localhost:8765,127.0.0.1:8765
# XHS_MCP_ALLOWED_ORIGINS=http://localhost:8765,http://127.0.0.1:8765
XHS_BROWSER_HEADLESS=true
# XHS_BROWSER_PATH=C:\Path\To\chrome.exe
# XHS_BROWSER_CHANNEL=chrome
# XHS_PROXY=http://user:password@proxy.example:8080
# XHS_AUTH_STATE_PATH=C:\Users\you\AppData\Local\xhs-read-mcp\storage_state.json
XHS_MAX_CONCURRENT_OPERATIONS=2
XHS_LOGIN_TIMEOUT_SECONDS=240
XHS_STATUS_TIMEOUT_SECONDS=30
XHS_SEARCH_TIMEOUT_SECONDS=60
XHS_DETAIL_TIMEOUT_SECONDS=60
XHS_COMMENT_TIMEOUT_SECONDS=300
XHS_TIMEZONE=Asia/Shanghai
XHS_LOG_LEVEL=INFO
